# Shared
NODE_ENV=production

# Backend
PORT=4000
VAULT_ROOT=/data/vault
API_BASE=/api/v1/vault
LOG_LEVEL=info
AUTH_ENABLED=false
VAULT_API_KEY_ADMIN=
VAULT_API_KEY_OPERATOR=
VAULT_API_KEY_READER=
INDEX_DB_PATH=/data/vault/memory/index.db
COMPACTION_INTERVAL_MS=0

# Frontend
FRONTEND_PORT=3000
NEXT_PUBLIC_VAULT_API_BASE=http://localhost:4000/api/v1/vault
NEXT_PUBLIC_VAULT_API_KEY=
